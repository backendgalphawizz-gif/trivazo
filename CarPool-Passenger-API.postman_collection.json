{
  "info": {
    "name": "Trivazo — CarPool Passenger API",
    "_postman_id": "trivazo-carpool-passenger-v1",
    "description": "Complete CarPool user/passenger API for Trivazo. Base URL: {{base_url}}/api/v1/carpool\n\nSetup:\n1. Set `base_url` in your environment (e.g. http://localhost:8000)\n2. Login via any existing auth endpoint to get a bearer token\n3. Set `auth_token` in your environment\n\nAll protected endpoints use: Authorization: Bearer {{auth_token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "route_id", "value": "1", "type": "string" },
    { "key": "booking_id", "value": "1", "type": "string" },
    { "key": "driver_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth (Existing)",
      "description": "Standard app user login/register to obtain bearer token for carpool passenger endpoints.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_or_phone\": \"user@example.com\",\n  \"password\": \"password\",\n  \"guest_id\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(res.token).to.be.a('string').and.not.empty);",
                  "",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('auth_token', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"phone\": \"+919876543210\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "pm.test('Has token', () => pm.expect(res.token).to.be.a('string'));",
                  "if (res.token) pm.collectionVariables.set('auth_token', res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Search & Routes (Public)",
      "description": "Public endpoints — no auth required.",
      "item": [
        {
          "name": "Search Available Trips",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/carpool/routes/search?origin_lat=19.0760&origin_lng=72.8777&destination_lat=18.5204&destination_lng=73.8567&date=2026-04-15&seats=1&radius_km=5&limit=15",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "carpool", "routes", "search"],
              "query": [
                { "key": "origin_lat",       "value": "19.0760",    "description": "Origin latitude (Mumbai)" },
                { "key": "origin_lng",       "value": "72.8777",    "description": "Origin longitude" },
                { "key": "destination_lat",  "value": "18.5204",    "description": "Destination latitude (Pune)" },
                { "key": "destination_lng",  "value": "73.8567",    "description": "Destination longitude" },
                { "key": "date",             "value": "2026-04-15", "description": "Trip date (Y-m-d)" },
                { "key": "seats",            "value": "1",          "description": "Number of seats needed" },
                { "key": "radius_km",        "value": "5",          "description": "Search radius in km (default 5)" },
                { "key": "limit",            "value": "15",         "description": "Results per page" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status flag true', () => pm.expect(res.status).to.be.true);",
                  "pm.test('Routes is array', () => pm.expect(res.routes).to.be.an('object'));",
                  "",
                  "// Save first route id for later requests",
                  "if (res.routes && res.routes.data && res.routes.data.length > 0) {",
                  "    pm.collectionVariables.set('route_id', res.routes.data[0].id);",
                  "    console.log('Saved route_id:', res.routes.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Trip Detail",
